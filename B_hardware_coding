#include <stdio.h>    /* stdio.h: printf, scanf, etc. */

int main(void) {      /* Einstiegspunkt – gibt int zurück (0 = Erfolg) */
    
    /* ── Datentypen ──────────────────────────────────── */
    int    ganz     = 42;        /* 32-Bit Integer (wie TOY, nur 32 statt 16 Bit) */
    char   zeichen  = 'A';       /* 8-Bit Zeichen */
    float  komma    = 3.14f;     /* 32-Bit Fließkomma */
    double genau    = 3.14159;   /* 64-Bit Fließkomma */
    
    /* ── Ausgabe ─────────────────────────────────────── */
    printf("ganz = %d\n",  ganz);       /* %d = dezimale Ganzzahl */
    printf("zeichen = %c\n", zeichen);  /* %c = Zeichen */
    printf("hex = %X\n",   ganz);       /* %X = Hexadezimal! (wie in TOY) */
    
    /* ── Eingabe ─────────────────────────────────────── */
    int eingabe;
    printf("Gib eine Zahl ein: ");
    scanf("%d", &eingabe);              /* & = Adresse von eingabe (Zeiger!) */
    printf("Du hast eingegeben: %d\n", eingabe);
    
    return 0;     /* 0 = Programm erfolgreich beendet */
