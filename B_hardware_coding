### 💻 Beispiel E1: Direkter Speicherzugriff in C – das moderne PEEK/POKE

In C gibt es kein PEEK/POKE – aber Zeiger machen dasselbe, strukturierter:

```c
/* beispiel_e1_speicher.c */
/* Zeigt: Zeiger sind das moderne PEEK/POKE */
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main(void) {
    /* ── Zeiger: Adresse einer Variable lesen und schreiben ─ */
    int x = 42;
    int *zeiger = &x;   /* zeiger = Adresse von x (wie PEEK-Adresse) */
    
    printf("Wert von x:      %d\n", x);
    printf("Adresse von x:   %p\n", (void*)&x);
    printf("Wert über Zeig.: %d\n", *zeiger);    /* PEEK */
    
    *zeiger = 100;                                 /* POKE */
    printf("x nach POKE:     %d\n", x);           /* x ist jetzt 100! */
    
    /* ── Speicher im Detail betrachten ─────────────────────── */
    /* Ein int ist 4 Bytes – schauen wir rein: */
    unsigned char *byte_zeiger = (unsigned char*)&x;
    printf("\nInt %d als 4 Bytes (little-endian):\n", x);
    for (int i = 0; i < 4; i++) {
        printf("  Byte %d (Adresse %p): %d (0x%02X)\n", 
               i, (void*)(byte_zeiger+i), byte_zeiger[i], byte_zeiger[i]);
    }
    
    /* ── Dynamischer Speicher: malloc/free ──────────────────── */
    int *array = malloc(5 * sizeof(int));
    if (array == NULL) {
        printf("Fehler: kein Speicher!\n");
        return 1;
    }
    
    for (int i = 0; i < 5; i++) {
        array[i] = (i+1) * 10;
    }
    
    printf("\nDynamisches Array: ");
    for (int i = 0; i < 5; i++) {
        printf("%d ", array[i]);
    }
    printf("\n");
    
    free(array);    /* PFLICHT! Kein Garbage Collector! */
    array = NULL;
    
    return 0;
}
```

